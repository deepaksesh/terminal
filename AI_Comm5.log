                                    },
                                    "status": {
                                        "type": "string",
                                        "enum": [
                                            "not-started",
                                            "in-progress",
                                            "completed"
                                        ],
                                        "description": "not-started: Not begun | in-progress: Currently working (max 1) | completed: Fully finished with no blockers"
                                    }
                                },
                                "required": [
                                    "id",
                                    "title",
                                    "status"
                                ]
                            }
                        }
